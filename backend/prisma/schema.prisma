generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]
  posts       BlogPost[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            Int              @id @default(autoincrement())
  name          String
  slug          String           @unique
  amazonAsin    String           @unique @map("amazon_asin")
  price         Decimal          @db.Decimal(10, 2)
  rating        Float            @default(0)
  imageUrl      String           @map("image_url")
  categoryId    Int              @map("category_id")
  description   String           @db.Text
  pros          Json
  cons          Json
  affiliateUrl  String           @map("affiliate_url")
  lastUpdated   DateTime         @map("last_updated") @default(now())
  category      Category         @relation(fields: [categoryId], references: [id])
  features      ProductFeature[]
  links         AffiliateLink[]
  priceHistory  PriceHistory[]
  clickTracking ClickTracking[]
  comparisonItems ComparisonTableItem[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([categoryId])
}

model ProductFeature {
  id        Int      @id @default(autoincrement())
  productId Int
  key       String
  value     String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model AffiliateLink {
  id         Int      @id @default(autoincrement())
  productId  Int
  source     String   @default("amazon")
  url        String
  clicks     Int      @default(0)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@unique([productId])
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  productId  Int
  oldPrice   Decimal  @db.Decimal(10, 2)
  newPrice   Decimal  @db.Decimal(10, 2)
  fetchedAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([fetchedAt])
}

model BlogPost {
  id                Int       @id @default(autoincrement())
  title             String
  slug              String    @unique
  content           String    @db.LongText
  excerpt           String?
  wordpressPostId   Int?      @unique @map("wordpress_post_id")
  status            String    @default("draft")
  seoTitle          String?   @map("seo_title")
  seoDescription    String?   @map("seo_description")
  categoryId        Int?      @map("category_id")
  category          Category? @relation(fields: [categoryId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ComparisonTable {
  id          Int                   @id @default(autoincrement())
  title       String
  slug        String                @unique
  description String?
  items       ComparisonTableItem[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model ComparisonTableItem {
  id                Int             @id @default(autoincrement())
  comparisonTableId Int             @map("comparison_table_id")
  productId         Int             @map("product_id")
  position          Int
  comparisonTable   ComparisonTable @relation(fields: [comparisonTableId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([comparisonTableId, productId])
  @@index([comparisonTableId])
  @@index([productId])
}

model ClickTracking {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  timestamp  DateTime @default(now())
  referrer   String?
  country    String?
  userAgent  String?  @map("user_agent")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([timestamp])
}

model AutomationLog {
  id         Int      @id @default(autoincrement())
  event      String
  status     String
  message    String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

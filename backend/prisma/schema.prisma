generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]
  posts       BlogPost[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            Int              @id @default(autoincrement())
  name          String
  slug          String           @unique
  amazonAsin    String           @unique @map("amazon_asin")
  price         Decimal          @db.Decimal(10, 2)
  rating        Float            @default(0)
  imageUrl      String           @map("image_url")
  categoryId    Int              @map("category_id")
  description   String           @db.Text
  pros          Json
  cons          Json
  affiliateUrl  String           @map("affiliate_url")
  lastUpdated   DateTime         @map("last_updated") @default(now())
  category      Category         @relation(fields: [categoryId], references: [id])
  features      ProductFeature[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([categoryId])
}

model ProductFeature {
  id        Int      @id @default(autoincrement())
  productId Int
  key       String
  value     String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model BlogPost {
  id                Int       @id @default(autoincrement())
  title             String
  slug              String    @unique
  content           String    @db.LongText
  excerpt           String?
  wordpressPostId   Int?      @unique @map("wordpress_post_id")
  status            String    @default("draft")
  seoTitle          String?   @map("seo_title")
  seoDescription    String?   @map("seo_description")
  categoryId        Int?      @map("category_id")
  category          Category? @relation(fields: [categoryId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Comparison {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  productIds  Json
  items       Json
  createdAt   DateTime @default(now())
}

model ClickEvent {
  id          Int      @id @default(autoincrement())
  slug        String
  ip          String?
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now())
}

model AutomationLog {
  id         Int      @id @default(autoincrement())
  event      String
  status     String
  message    String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

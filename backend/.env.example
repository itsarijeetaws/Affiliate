PORT=4000
DATABASE_URL="mysql://root:password@localhost:3306/affiliate_db"
JWT_SECRET="change-me"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
AUTOMATION_API_KEY="change-automation-key"
FRONTEND_URL="http://localhost:3000"
REDIS_URL="redis://localhost:6379"
ENABLE_DAILY_CRON=true
WORDPRESS_BASE_URL="https://cms.example.com"
WORDPRESS_USERNAME="wp_api_user"
WORDPRESS_APP_PASSWORD="app-password"
# Amazon Creators API (OAuth2) — get from affiliate-program.amazon.in → Creators API
AMAZON_CLIENT_ID=""
AMAZON_CLIENT_SECRET=""
AMAZON_PARTNER_TAG=""
# Legacy PA API keys (no longer needed if using Creators API above)
# AMAZON_ACCESS_KEY=""
# AMAZON_SECRET_KEY=""
# Optional LLM keys — content generation tries Gemini, then Anthropic, then OpenAI
# GEMINI_API_KEY=""
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""

# Pinterest auto-posting
# How to get tokens: developers.pinterest.com → create app → OAuth2 (scopes: boards:read, pins:write)
# PINTEREST_CLIENT_ID=""
# PINTEREST_CLIENT_SECRET=""
# PINTEREST_ACCESS_TOKEN=""       # Bearer token from OAuth2 exchange
# PINTEREST_REFRESH_TOKEN=""      # For auto-refresh when access token expires
# PINTEREST_BOARD_ID=""           # Board ID from pinterest.com/boardname/ or API
# PINTEREST_CRON="0 */6 * * *"   # Cron schedule (default: every 6 hours)
# PINTEREST_PINS_PER_RUN="3"     # Pins to post per run (max 10)
# PINTEREST_MIN_RATING="4.0"     # Minimum product rating to pin
